# =============================================================================
# Backend environment variables — copy to .env and fill in your values
# =============================================================================

# PostgreSQL connection string (Neon free tier)
# Get this from: https://console.neon.tech → your project → Connection Details
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?sslmode=require

# Groq API key for AI triage (llama-3.1-8b-instant)
# Get this from: https://console.groq.com → API Keys
GROQ_API_KEY=gsk_your_key_here

# Comma-separated list of allowed frontend origins (for CORS)
# In production, set this to your Vercel URL
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: comma-separated IPs/hostnames that are exempt from the SSRF denylist
# Use this only if you're scanning your own private infrastructure
ALLOWED_PRIVATE_TARGETS=
